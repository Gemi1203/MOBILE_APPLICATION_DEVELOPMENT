rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Driver locations: only the driver may write/read their own location
    match /driver_locations/{driverId} {
      allow read, write: if request.auth != null && request.auth.uid == driverId;
    }

    // Anomalies: drivers may create anomalies, managers/admins can read
    match /anomalies/{anomalyId} {
      allow create: if request.auth != null;
      allow read: if isManagerOrAdmin();
      allow update: if isManagerOrAdmin();
    }

    // Geofence events: only system writes expected, managers/admins can read
    match /geofence_events/{eventId} {
      allow create: if request.auth != null;
      allow read: if isManagerOrAdmin();
    }

    // A helper to check user role
    function isManagerOrAdmin() {
      return request.auth != null && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['manager', 'admin']);
    }
  }
}
